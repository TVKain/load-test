SCRAPING_API_URL=https://ml.cloudcix.com/scraping/
SCRAPING_API_KEY=your-api-key-here
SCRAPING_DOCUMENT_TYPE=html
SCRAPING_URLS_FILE=html

# Optional: Sleep time (seconds) between iterations per VU
SCRAPING_SLEEP_MIN=0.5
SCRAPING_SLEEP_MAX=2.5

# Optional: HTML exclusions (JSON format)
# SCRAPING_EXCLUSIONS={"exclusion_tags":["script","style"],"exclusion_classes":["footer","header"]}

PRESET=smoke
