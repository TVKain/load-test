# =============================================================================
# k6-cloudcix-chatbot — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[codz]
*$py.class
*.so
venv/
*.egg-info/

# Test Results
contact/results/
openai/results/
scraping/results/
*.json
*.png
summary.txt

# Environment Files
.env
contact/.env
openai/.env
scraping/.env

# Environment directories - keep *.example.env files
contact/envs/*.env
!contact/envs/*.example.env
openai/envs/*.env
!openai/envs/*.example.env
scraping/envs/*.env
!scraping/envs/*.example.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

