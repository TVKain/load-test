OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=sk-1234567890
OPENAI_MODEL=UCCIX-Mistral-24B

# Deterministic decoding settings (if backend supports seed)
OPENAI_TEMPERATURE=0
OPENAI_TOP_P=1
OPENAI_SEED=42

# Sleep time (seconds) between iterations per VU (default: 0.5–2.5s random)
OPENAI_SLEEP_MIN=0.5
OPENAI_SLEEP_MAX=2.5
\n# Disable HTTP keep-alive to force fresh connections (useful for measuring cold-start latency)
# OPENAI_DISABLE_KEEPALIVE=true

